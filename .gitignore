# Native packaging layer (Capacitor) — see package.json / CAPACITOR_BUILD.md.
# The web app itself stays no-build and is committed as-is at the repo root;
# everything below is generated or installed and rebuilt by CI, never committed.

# npm
node_modules/

# Generated web bundle Capacitor copies into the native project.
# Rebuilt by `npm run assemble` (scripts/assemble-www.mjs) in CI.
/www/

# Capacitor copies the web assets + a config into the Android project on sync;
# regenerated by `cap sync` in CI, so keep them out of git.
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json

# Android/Gradle local + build outputs (android/.gitignore covers most; belt & braces)
android/.gradle/
android/local.properties
android/app/build/
android/build/
