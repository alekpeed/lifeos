{
  "name": "lifeos-native",
  "version": "1.0.0",
  "private": true,
  "description": "Native-shell packaging layer for the LifeOS PWA. The web app itself stays no-build vanilla JS served from the repo root; this exists only so Capacitor can wrap those same files into a native Android/desktop app. Nothing here runs for the GitHub Pages web deploy.",
  "type": "module",
  "scripts": {
    "assemble": "node scripts/assemble-www.mjs",
    "cap:sync": "npm run assemble && cap sync",
    "cap:copy": "npm run assemble && cap copy"
  },
  "dependencies": {
    "@capacitor-community/contacts": "^6.1.1",
    "@capacitor-community/keep-awake": "^5.0.1",
    "@capacitor-community/text-to-speech": "^5.1.0",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/device": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/share": "^6.0.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
