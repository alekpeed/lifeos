[
  { "schemaVersion": 1, "key": "vocab.agua", "entryType": "word", "lemma": "água", "translation": "water", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈa.gwɐ", "gender": "f", "register": "neutral", "tags": ["food-drink"], "examples": [{ "text": "Quero um copo de água.", "translation": "I want a glass of water." }] },
  { "schemaVersion": 1, "key": "vocab.cafe", "entryType": "word", "lemma": "café", "translation": "coffee", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["food-drink"], "examples": [{ "text": "Um café, por favor.", "translation": "A coffee, please." }] },
  { "schemaVersion": 1, "key": "vocab.pao", "entryType": "word", "lemma": "pão", "translation": "bread", "partOfSpeech": "noun", "cefr": "A1", "ipa": "pɐ̃w̃", "gender": "m", "register": "neutral", "tags": ["food-drink"], "pronunciationNotes": "Nasal diphthong -ão: let the air go through the nose, no final 'n' sound.", "examples": [{ "text": "Comprei pão na padaria.", "translation": "I bought bread at the bakery." }] },
  { "schemaVersion": 1, "key": "vocab.leite", "entryType": "word", "lemma": "leite", "translation": "milk", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈlej.tʃi", "gender": "m", "register": "neutral", "tags": ["food-drink"], "pronunciationNotes": "Final -te sounds like 'chee' in most of Brazil." },
  { "schemaVersion": 1, "key": "vocab.casa", "entryType": "word", "lemma": "casa", "translation": "house / home", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["home"], "examples": [{ "text": "Vou pra casa depois do trabalho.", "translation": "I'm going home after work.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.rua", "entryType": "word", "lemma": "rua", "translation": "street", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈʁu.ɐ", "gender": "f", "register": "neutral", "tags": ["city"], "pronunciationNotes": "Initial r is a harsh 'h' sound in Brazilian Portuguese, like English 'who-ah'." },
  { "schemaVersion": 1, "key": "vocab.amigo", "entryType": "word", "lemma": "amigo", "translation": "friend", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["people"], "examples": [{ "text": "Ele é meu melhor amigo.", "translation": "He is my best friend." }] },
  { "schemaVersion": 1, "key": "vocab.falar", "entryType": "word", "lemma": "falar", "translation": "to speak", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "Eu falo português.", "translation": "I speak Portuguese." }] },
  { "schemaVersion": 1, "key": "vocab.comer", "entryType": "word", "lemma": "comer", "translation": "to eat", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "O que você quer comer hoje?", "translation": "What do you want to eat today?" }] },
  { "schemaVersion": 1, "key": "vocab.beber", "entryType": "word", "lemma": "beber", "translation": "to drink", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "Você quer beber alguma coisa?", "translation": "Do you want to drink something?" }] },
  { "schemaVersion": 1, "key": "vocab.hoje", "entryType": "word", "lemma": "hoje", "translation": "today", "partOfSpeech": "adverb", "cefr": "A1", "ipa": "ˈo.ʒi", "register": "neutral", "tags": ["time"], "examples": [{ "text": "Hoje eu não trabalho.", "translation": "Today I don't work." }] },
  { "schemaVersion": 1, "key": "vocab.obrigado", "entryType": "word", "lemma": "obrigado", "translation": "thank you (said by a man)", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["courtesy"], "pronunciationNotes": "Women say 'obrigada'; the ending agrees with the speaker's gender." },
  { "schemaVersion": 1, "key": "vocab.oi", "entryType": "word", "lemma": "oi", "translation": "hi", "partOfSpeech": "interjection", "cefr": "A1", "frequencyRank": 150, "register": "neutral", "tags": ["greeting"], "examples": [{ "text": "Oi! Que bom te ver.", "translation": "Hi! Good to see you." }] },
  { "schemaVersion": 1, "key": "vocab.bom-dia", "entryType": "word", "lemma": "bom dia", "translation": "good morning", "partOfSpeech": "interjection", "cefr": "A1", "register": "neutral", "tags": ["greeting"], "pronunciationNotes": "The 'dia' sounds like 'JEE-ah' in most of Brazil." },
  { "schemaVersion": 1, "key": "vocab.boa-tarde", "entryType": "word", "lemma": "boa tarde", "translation": "good afternoon", "partOfSpeech": "interjection", "cefr": "A1", "ipa": "ˈbo.ɐ ˈtaʁ.dʒi", "register": "neutral", "tags": ["greeting"] },
  { "schemaVersion": 1, "key": "vocab.boa-noite", "entryType": "word", "lemma": "boa noite", "translation": "good evening / good night", "partOfSpeech": "interjection", "cefr": "A1", "ipa": "ˈbo.ɐ ˈnoj.tʃi", "register": "neutral", "tags": ["greeting"], "naturalMeaning": "Used both when arriving in the evening and when saying goodbye at night." },
  { "schemaVersion": 1, "key": "vocab.tchau", "entryType": "word", "lemma": "tchau", "translation": "bye", "partOfSpeech": "interjection", "cefr": "A1", "ipa": "tʃaw", "register": "neutral", "tags": ["greeting"], "naturalMeaning": "From Italian 'ciao', but in Brazil it is only used for goodbye, never for hello." },
  { "schemaVersion": 1, "key": "vocab.desculpa", "entryType": "word", "lemma": "desculpa", "translation": "sorry", "partOfSpeech": "interjection", "cefr": "A1", "register": "informal", "tags": ["courtesy"], "naturalMeaning": "'Desculpe' is the slightly more formal variant; 'desculpa' is what you hear day to day.", "examples": [{ "text": "Desculpa o atraso!", "translation": "Sorry for being late!", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.sim", "entryType": "word", "lemma": "sim", "translation": "yes", "partOfSpeech": "adverb", "cefr": "A1", "ipa": "sĩ", "register": "neutral", "tags": ["basics"], "naturalMeaning": "Brazilians often answer by repeating the verb instead: 'Você quer? — Quero.'" },
  { "schemaVersion": 1, "key": "vocab.nao", "entryType": "word", "lemma": "não", "translation": "no / not", "partOfSpeech": "adverb", "cefr": "A1", "frequencyRank": 10, "ipa": "nɐ̃w̃", "register": "neutral", "tags": ["basics"], "pronunciationNotes": "Nasal diphthong; sounds like 'now' said through the nose.", "examples": [{ "text": "Não, obrigado.", "translation": "No, thank you." }] },
  { "schemaVersion": 1, "key": "vocab.um", "entryType": "word", "lemma": "um", "translation": "one", "partOfSpeech": "numeral", "cefr": "A1", "ipa": "ũ", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "Also the masculine indefinite article 'a/an'; feminine form is 'uma'." },
  { "schemaVersion": 1, "key": "vocab.dois", "entryType": "word", "lemma": "dois", "translation": "two", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "Feminine form is 'duas': duas cervejas." },
  { "schemaVersion": 1, "key": "vocab.tres", "entryType": "word", "lemma": "três", "translation": "three", "partOfSpeech": "numeral", "cefr": "A1", "ipa": "tɾes", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.quatro", "entryType": "word", "lemma": "quatro", "translation": "four", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.cinco", "entryType": "word", "lemma": "cinco", "translation": "five", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.seis", "entryType": "word", "lemma": "seis", "translation": "six", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "On the phone Brazilians often say 'meia' (half a dozen) instead of 'seis' to avoid confusion with 'três'." },
  { "schemaVersion": 1, "key": "vocab.sete", "entryType": "word", "lemma": "sete", "translation": "seven", "partOfSpeech": "numeral", "cefr": "A1", "ipa": "ˈsɛ.tʃi", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.oito", "entryType": "word", "lemma": "oito", "translation": "eight", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.nove", "entryType": "word", "lemma": "nove", "translation": "nine", "partOfSpeech": "numeral", "cefr": "A1", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.dez", "entryType": "word", "lemma": "dez", "translation": "ten", "partOfSpeech": "numeral", "cefr": "A1", "ipa": "dɛs", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.vinte", "entryType": "word", "lemma": "vinte", "translation": "twenty", "partOfSpeech": "numeral", "cefr": "A1", "ipa": "ˈvĩ.tʃi", "register": "neutral", "tags": ["numbers"] },
  { "schemaVersion": 1, "key": "vocab.cem", "entryType": "word", "lemma": "cem", "translation": "one hundred", "partOfSpeech": "numeral", "cefr": "A1", "ipa": "sẽj̃", "register": "neutral", "tags": ["numbers"], "naturalMeaning": "'Cem' is exactly 100; from 101 to 199 it becomes 'cento': cento e dez." },
  { "schemaVersion": 1, "key": "vocab.mil", "entryType": "word", "lemma": "mil", "translation": "one thousand", "partOfSpeech": "numeral", "cefr": "A1", "ipa": "miw", "register": "neutral", "tags": ["numbers"], "pronunciationNotes": "Final -l sounds like 'w' in Brazil: 'meew'." },
  { "schemaVersion": 1, "key": "vocab.dia", "entryType": "word", "lemma": "dia", "translation": "day", "partOfSpeech": "noun", "cefr": "A1", "frequencyRank": 90, "ipa": "ˈdʒi.ɐ", "gender": "m", "register": "neutral", "tags": ["time"], "pronunciationNotes": "Masculine despite ending in -a: o dia. The 'di' sounds like 'jee'." },
  { "schemaVersion": 1, "key": "vocab.semana", "entryType": "word", "lemma": "semana", "translation": "week", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["time"], "examples": [{ "text": "Semana que vem eu viajo.", "translation": "Next week I'm traveling." }] },
  { "schemaVersion": 1, "key": "vocab.mes", "entryType": "word", "lemma": "mês", "translation": "month", "partOfSpeech": "noun", "cefr": "A1", "ipa": "mes", "gender": "m", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.ano", "entryType": "word", "lemma": "ano", "translation": "year", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["time"], "examples": [{ "text": "Eu tenho trinta anos.", "translation": "I am thirty years old." }] },
  { "schemaVersion": 1, "key": "vocab.hora", "entryType": "word", "lemma": "hora", "translation": "hour / time (on the clock)", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈɔ.ɾɐ", "gender": "f", "register": "neutral", "tags": ["time"], "examples": [{ "text": "Que horas são?", "translation": "What time is it?" }] },
  { "schemaVersion": 1, "key": "vocab.manha", "entryType": "word", "lemma": "manhã", "translation": "morning", "partOfSpeech": "noun", "cefr": "A1", "ipa": "mɐ̃ˈɲɐ̃", "gender": "f", "register": "neutral", "tags": ["time"], "pronunciationNotes": "Both vowels are nasal; the 'nh' is like the 'ny' in 'canyon'." },
  { "schemaVersion": 1, "key": "vocab.tarde", "entryType": "word", "lemma": "tarde", "translation": "afternoon; late", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈtaʁ.dʒi", "gender": "f", "register": "neutral", "tags": ["time"], "naturalMeaning": "As an adverb it means 'late': cheguei tarde.", "pronunciationNotes": "The 'de' sounds like 'jee' in most of Brazil." },
  { "schemaVersion": 1, "key": "vocab.noite", "entryType": "word", "lemma": "noite", "translation": "night / evening", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈnoj.tʃi", "gender": "f", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.amanha", "entryType": "word", "lemma": "amanhã", "translation": "tomorrow", "partOfSpeech": "adverb", "cefr": "A1", "ipa": "a.mɐ̃ˈɲɐ̃", "register": "neutral", "tags": ["time"], "examples": [{ "text": "A gente se fala amanhã.", "translation": "We'll talk tomorrow.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.ontem", "entryType": "word", "lemma": "ontem", "translation": "yesterday", "partOfSpeech": "adverb", "cefr": "A1", "ipa": "ˈõ.tẽj̃", "register": "neutral", "tags": ["time"] },
  { "schemaVersion": 1, "key": "vocab.agora", "entryType": "word", "lemma": "agora", "translation": "now", "partOfSpeech": "adverb", "cefr": "A1", "frequencyRank": 120, "register": "neutral", "tags": ["time"], "examples": [{ "text": "Não posso falar agora.", "translation": "I can't talk now." }] },
  { "schemaVersion": 1, "key": "vocab.sempre", "entryType": "word", "lemma": "sempre", "translation": "always", "partOfSpeech": "adverb", "cefr": "A1", "ipa": "ˈsẽ.pɾi", "register": "neutral", "tags": ["time"], "examples": [{ "text": "Eu sempre tomo café de manhã.", "translation": "I always drink coffee in the morning." }] },
  { "schemaVersion": 1, "key": "vocab.segunda-feira", "entryType": "word", "lemma": "segunda-feira", "translation": "Monday", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["time", "days"], "naturalMeaning": "Weekdays are 'ordinal + feira': segunda to sexta. In speech people drop 'feira': 'na segunda'.", "examples": [{ "text": "Volto ao trabalho na segunda.", "translation": "I go back to work on Monday.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.domingo", "entryType": "word", "lemma": "domingo", "translation": "Sunday", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["time", "days"], "examples": [{ "text": "Domingo tem churrasco na casa da minha mãe.", "translation": "Sunday there's a barbecue at my mom's house." }] },
  { "schemaVersion": 1, "key": "vocab.familia", "entryType": "word", "lemma": "família", "translation": "family", "partOfSpeech": "noun", "cefr": "A1", "ipa": "faˈmi.ljɐ", "gender": "f", "register": "neutral", "tags": ["family"] },
  { "schemaVersion": 1, "key": "vocab.mae", "entryType": "word", "lemma": "mãe", "translation": "mother", "partOfSpeech": "noun", "cefr": "A1", "ipa": "mɐ̃j̃", "gender": "f", "register": "neutral", "tags": ["family"], "pronunciationNotes": "Nasal diphthong, like 'my' said through the nose." },
  { "schemaVersion": 1, "key": "vocab.pai", "entryType": "word", "lemma": "pai", "translation": "father", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["family"], "naturalMeaning": "'Pais' means both 'fathers' and 'parents'." },
  { "schemaVersion": 1, "key": "vocab.filho", "entryType": "word", "lemma": "filho", "translation": "son", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈfi.ʎu", "gender": "m", "register": "neutral", "tags": ["family"], "naturalMeaning": "'Filha' is daughter; 'filhos' can mean 'children' in general.", "pronunciationNotes": "The 'lh' is like the 'lli' in 'million'." },
  { "schemaVersion": 1, "key": "vocab.irmao", "entryType": "word", "lemma": "irmão", "translation": "brother", "partOfSpeech": "noun", "cefr": "A1", "ipa": "iʁˈmɐ̃w̃", "gender": "m", "register": "neutral", "tags": ["family"], "naturalMeaning": "'Irmã' is sister. Also used informally to address a friend, like 'bro'." },
  { "schemaVersion": 1, "key": "vocab.homem", "entryType": "word", "lemma": "homem", "translation": "man", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈo.mẽj̃", "gender": "m", "register": "neutral", "tags": ["people"], "pronunciationNotes": "The 'h' is silent; final -em is nasal." },
  { "schemaVersion": 1, "key": "vocab.mulher", "entryType": "word", "lemma": "mulher", "translation": "woman; wife", "partOfSpeech": "noun", "cefr": "A1", "ipa": "muˈʎɛʁ", "gender": "f", "register": "neutral", "tags": ["people"], "naturalMeaning": "'Minha mulher' commonly means 'my wife' in everyday speech." },
  { "schemaVersion": 1, "key": "vocab.comida", "entryType": "word", "lemma": "comida", "translation": "food", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["food-drink"], "examples": [{ "text": "A comida daqui é muito boa.", "translation": "The food here is really good." }] },
  { "schemaVersion": 1, "key": "vocab.feijao", "entryType": "word", "lemma": "feijão", "translation": "beans", "partOfSpeech": "noun", "cefr": "A1", "ipa": "fejˈʒɐ̃w̃", "gender": "m", "register": "neutral", "tags": ["food-drink", "brazil"], "naturalMeaning": "Rice and beans (arroz com feijão) is the default Brazilian everyday meal.", "examples": [{ "text": "No Brasil, quase todo mundo come arroz com feijão.", "translation": "In Brazil, almost everyone eats rice and beans." }] },
  { "schemaVersion": 1, "key": "vocab.arroz", "entryType": "word", "lemma": "arroz", "translation": "rice", "partOfSpeech": "noun", "cefr": "A1", "ipa": "aˈʁos", "gender": "m", "register": "neutral", "tags": ["food-drink"], "pronunciationNotes": "Double-r sound is a harsh 'h': 'a-HOS'." },
  { "schemaVersion": 1, "key": "vocab.carne", "entryType": "word", "lemma": "carne", "translation": "meat; beef", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈkaʁ.ni", "gender": "f", "register": "neutral", "tags": ["food-drink"], "naturalMeaning": "On a menu, 'carne' by itself usually means beef." },
  { "schemaVersion": 1, "key": "vocab.frango", "entryType": "word", "lemma": "frango", "translation": "chicken", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈfɾɐ̃.gu", "gender": "m", "register": "neutral", "tags": ["food-drink"] },
  { "schemaVersion": 1, "key": "vocab.peixe", "entryType": "word", "lemma": "peixe", "translation": "fish", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈpej.ʃi", "gender": "m", "register": "neutral", "tags": ["food-drink"] },
  { "schemaVersion": 1, "key": "vocab.cerveja", "entryType": "word", "lemma": "cerveja", "translation": "beer", "partOfSpeech": "noun", "cefr": "A1", "ipa": "seʁˈve.ʒɐ", "gender": "f", "register": "neutral", "tags": ["food-drink"], "examples": [{ "text": "Uma cerveja bem gelada, por favor.", "translation": "A very cold beer, please." }] },
  { "schemaVersion": 1, "key": "vocab.churrasco", "entryType": "word", "lemma": "churrasco", "translation": "barbecue", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ʃuˈʁas.ku", "gender": "m", "register": "neutral", "tags": ["food-drink", "brazil"], "naturalMeaning": "Both the grilled meat and the social event; a weekend churrasco is a core Brazilian institution.", "examples": [{ "text": "Vamos fazer um churrasco no sábado?", "translation": "Shall we have a barbecue on Saturday?" }] },
  { "schemaVersion": 1, "key": "vocab.acai", "entryType": "word", "lemma": "açaí", "translation": "açaí (Amazonian berry, eaten as a thick frozen pulp)", "partOfSpeech": "noun", "cefr": "A1", "ipa": "a.saˈi", "gender": "m", "register": "neutral", "tags": ["food-drink", "brazil"], "pronunciationNotes": "Three syllables, stress on the last: ah-sah-EE." },
  { "schemaVersion": 1, "key": "vocab.cachaca", "entryType": "word", "lemma": "cachaça", "translation": "cachaça (Brazilian sugarcane spirit)", "partOfSpeech": "noun", "cefr": "A1", "ipa": "kaˈʃa.sɐ", "gender": "f", "register": "neutral", "tags": ["food-drink", "brazil"], "naturalMeaning": "The base of the caipirinha; also called 'pinga' informally." },
  { "schemaVersion": 1, "key": "vocab.chope", "entryType": "word", "lemma": "chope", "translation": "draft beer", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈʃo.pi", "gender": "m", "register": "neutral", "tags": ["food-drink", "brazil"], "examples": [{ "text": "Dois chopes, por favor!", "translation": "Two draft beers, please!" }] },
  { "schemaVersion": 1, "key": "vocab.almoco", "entryType": "word", "lemma": "almoço", "translation": "lunch", "partOfSpeech": "noun", "cefr": "A1", "ipa": "awˈmo.su", "gender": "m", "register": "neutral", "tags": ["food-drink"], "naturalMeaning": "Lunch is the main meal of the day for most Brazilians." },
  { "schemaVersion": 1, "key": "vocab.jantar", "entryType": "word", "lemma": "jantar", "translation": "dinner; to have dinner", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ʒɐ̃ˈtaʁ", "gender": "m", "register": "neutral", "tags": ["food-drink"], "examples": [{ "text": "Quer jantar comigo hoje?", "translation": "Do you want to have dinner with me tonight?" }] },
  { "schemaVersion": 1, "key": "vocab.conta", "entryType": "word", "lemma": "conta", "translation": "bill / check", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["food-drink", "money"], "examples": [{ "text": "Pode trazer a conta, por favor?", "translation": "Can you bring the bill, please?" }] },
  { "schemaVersion": 1, "key": "vocab.ser", "entryType": "word", "lemma": "ser", "translation": "to be (permanent traits, identity)", "partOfSpeech": "verb", "cefr": "A1", "frequencyRank": 5, "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "Used for identity and permanent qualities; contrast with 'estar' for temporary states.", "examples": [{ "text": "Eu sou americano.", "translation": "I am American." }, { "text": "Ela é professora.", "translation": "She is a teacher." }] },
  { "schemaVersion": 1, "key": "vocab.estar", "entryType": "word", "lemma": "estar", "translation": "to be (states, locations)", "partOfSpeech": "verb", "cefr": "A1", "frequencyRank": 20, "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "In speech, forms are shortened: estou → tô, está → tá.", "examples": [{ "text": "Tô cansado hoje.", "translation": "I'm tired today.", "register": "informal" }, { "text": "Onde você está?", "translation": "Where are you?" }] },
  { "schemaVersion": 1, "key": "vocab.ter", "entryType": "word", "lemma": "ter", "translation": "to have", "partOfSpeech": "verb", "cefr": "A1", "frequencyRank": 8, "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "Also means 'there is/are' in spoken Brazilian: 'Tem um mercado aqui perto.'", "examples": [{ "text": "Eu tenho dois irmãos.", "translation": "I have two brothers." }, { "text": "Tem açúcar?", "translation": "Is there any sugar? / Do you have sugar?" }] },
  { "schemaVersion": 1, "key": "vocab.ir", "entryType": "word", "lemma": "ir", "translation": "to go", "partOfSpeech": "verb", "cefr": "A1", "frequencyRank": 30, "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "'Ir + infinitive' is the everyday future: 'Vou comprar pão.'", "examples": [{ "text": "Vou pra praia amanhã.", "translation": "I'm going to the beach tomorrow.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.fazer", "entryType": "word", "lemma": "fazer", "translation": "to do / to make", "partOfSpeech": "verb", "cefr": "A1", "frequencyRank": 25, "register": "neutral", "tags": ["verb", "core"], "examples": [{ "text": "O que você vai fazer hoje?", "translation": "What are you going to do today?" }, { "text": "Faz calor no verão.", "translation": "It's hot in the summer." }] },
  { "schemaVersion": 1, "key": "vocab.querer", "entryType": "word", "lemma": "querer", "translation": "to want", "partOfSpeech": "verb", "cefr": "A1", "frequencyRank": 40, "register": "neutral", "tags": ["verb", "core"], "examples": [{ "text": "Quero um suco de laranja.", "translation": "I want an orange juice." }] },
  { "schemaVersion": 1, "key": "vocab.poder", "entryType": "word", "lemma": "poder", "translation": "can / to be able to", "partOfSpeech": "verb", "cefr": "A1", "frequencyRank": 35, "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "'Pode?' alone asks permission; 'Pode.' alone grants it.", "examples": [{ "text": "Posso sentar aqui?", "translation": "Can I sit here?" }] },
  { "schemaVersion": 1, "key": "vocab.gostar", "entryType": "word", "lemma": "gostar", "translation": "to like", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "Always takes 'de': gostar de alguma coisa.", "examples": [{ "text": "Eu gosto muito de música brasileira.", "translation": "I really like Brazilian music." }] },
  { "schemaVersion": 1, "key": "vocab.ficar", "entryType": "word", "lemma": "ficar", "translation": "to stay; to become; to be located", "partOfSpeech": "verb", "cefr": "A1", "frequencyRank": 60, "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "Extremely versatile. Also 'ficar com alguém' = to make out / hook up with someone (informal).", "examples": [{ "text": "Onde fica o banheiro?", "translation": "Where is the bathroom?" }, { "text": "Vou ficar em casa hoje.", "translation": "I'm going to stay home today." }] },
  { "schemaVersion": 1, "key": "vocab.saber", "entryType": "word", "lemma": "saber", "translation": "to know (facts, how to)", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "For knowing people or places, use 'conhecer' instead.", "examples": [{ "text": "Você sabe que horas são?", "translation": "Do you know what time it is?" }] },
  { "schemaVersion": 1, "key": "vocab.ver", "entryType": "word", "lemma": "ver", "translation": "to see", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb", "core"], "examples": [{ "text": "Deixa eu ver.", "translation": "Let me see.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.dar", "entryType": "word", "lemma": "dar", "translation": "to give", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "Also the all-purpose 'to be possible': 'Dá pra fazer' = it can be done; 'Não deu' = it didn't work out.", "examples": [{ "text": "Dá pra chegar a pé?", "translation": "Can you get there on foot?", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.dizer", "entryType": "word", "lemma": "dizer", "translation": "to say", "partOfSpeech": "verb", "cefr": "A1", "ipa": "dʒiˈzeʁ", "register": "neutral", "tags": ["verb", "core"], "naturalMeaning": "In everyday speech Brazilians often prefer 'falar': 'Ele falou que vem.'", "examples": [{ "text": "O que você quer dizer?", "translation": "What do you mean?" }] },
  { "schemaVersion": 1, "key": "vocab.trabalhar", "entryType": "word", "lemma": "trabalhar", "translation": "to work", "partOfSpeech": "verb", "cefr": "A1", "ipa": "tɾa.baˈʎaʁ", "register": "neutral", "tags": ["verb", "work"], "examples": [{ "text": "Eu trabalho de casa.", "translation": "I work from home." }] },
  { "schemaVersion": 1, "key": "vocab.morar", "entryType": "word", "lemma": "morar", "translation": "to live (reside)", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "naturalMeaning": "For residing somewhere; 'viver' is for being alive / life in general.", "examples": [{ "text": "Eu moro em São Paulo.", "translation": "I live in São Paulo." }] },
  { "schemaVersion": 1, "key": "vocab.estudar", "entryType": "word", "lemma": "estudar", "translation": "to study", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "Estou estudando português.", "translation": "I'm studying Portuguese." }] },
  { "schemaVersion": 1, "key": "vocab.entender", "entryType": "word", "lemma": "entender", "translation": "to understand", "partOfSpeech": "verb", "cefr": "A1", "ipa": "ẽ.tẽˈdeʁ", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "Entendi tudo!", "translation": "I understood everything!" }] },
  { "schemaVersion": 1, "key": "vocab.ajudar", "entryType": "word", "lemma": "ajudar", "translation": "to help", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb"], "examples": [{ "text": "Posso te ajudar?", "translation": "Can I help you?" }] },
  { "schemaVersion": 1, "key": "vocab.comprar", "entryType": "word", "lemma": "comprar", "translation": "to buy", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb", "shopping"], "examples": [{ "text": "Preciso comprar frutas no mercado.", "translation": "I need to buy fruit at the market." }] },
  { "schemaVersion": 1, "key": "vocab.pagar", "entryType": "word", "lemma": "pagar", "translation": "to pay", "partOfSpeech": "verb", "cefr": "A1", "register": "neutral", "tags": ["verb", "money"], "examples": [{ "text": "Hoje eu pago a conta.", "translation": "Today I'm paying the bill." }] },
  { "schemaVersion": 1, "key": "vocab.pedir", "entryType": "word", "lemma": "pedir", "translation": "to ask for / to order", "partOfSpeech": "verb", "cefr": "A1", "ipa": "peˈdʒiʁ", "register": "neutral", "tags": ["verb", "food-drink"], "examples": [{ "text": "Vamos pedir uma pizza?", "translation": "Shall we order a pizza?" }] },
  { "schemaVersion": 1, "key": "vocab.bom", "entryType": "word", "lemma": "bom", "translation": "good", "partOfSpeech": "adjective", "cefr": "A1", "frequencyRank": 100, "ipa": "bõ", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "Feminine: boa. 'Tá bom' = okay, fine.", "examples": [{ "text": "Esse restaurante é muito bom.", "translation": "This restaurant is really good." }] },
  { "schemaVersion": 1, "key": "vocab.grande", "entryType": "word", "lemma": "grande", "translation": "big", "partOfSpeech": "adjective", "cefr": "A1", "ipa": "ˈgɾɐ̃.dʒi", "register": "neutral", "tags": ["adjective"] },
  { "schemaVersion": 1, "key": "vocab.pequeno", "entryType": "word", "lemma": "pequeno", "translation": "small", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "Brazilians often use the diminutive -inho instead: 'um cafezinho' (a little coffee)." },
  { "schemaVersion": 1, "key": "vocab.novo", "entryType": "word", "lemma": "novo", "translation": "new; young", "partOfSpeech": "adjective", "cefr": "A1", "ipa": "ˈno.vu", "register": "neutral", "tags": ["adjective"], "naturalMeaning": "'Ela é nova' usually means 'she is young', not 'new'." },
  { "schemaVersion": 1, "key": "vocab.bonito", "entryType": "word", "lemma": "bonito", "translation": "beautiful / handsome", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective"], "examples": [{ "text": "Que praia bonita!", "translation": "What a beautiful beach!" }] },
  { "schemaVersion": 1, "key": "vocab.quente", "entryType": "word", "lemma": "quente", "translation": "hot", "partOfSpeech": "adjective", "cefr": "A1", "ipa": "ˈkẽ.tʃi", "register": "neutral", "tags": ["adjective", "weather"], "naturalMeaning": "For weather, Brazilians say 'Tá calor' or 'Tá quente'." },
  { "schemaVersion": 1, "key": "vocab.frio", "entryType": "word", "lemma": "frio", "translation": "cold", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective", "weather"], "examples": [{ "text": "Tô com frio.", "translation": "I'm cold.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.caro", "entryType": "word", "lemma": "caro", "translation": "expensive", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective", "shopping"], "examples": [{ "text": "Nossa, que caro!", "translation": "Wow, that's expensive!", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.barato", "entryType": "word", "lemma": "barato", "translation": "cheap", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["adjective", "shopping"] },
  { "schemaVersion": 1, "key": "vocab.facil", "entryType": "word", "lemma": "fácil", "translation": "easy", "partOfSpeech": "adjective", "cefr": "A1", "ipa": "ˈfa.siw", "register": "neutral", "tags": ["adjective"], "pronunciationNotes": "Final -l sounds like 'w': FAH-seew." },
  { "schemaVersion": 1, "key": "vocab.dificil", "entryType": "word", "lemma": "difícil", "translation": "difficult", "partOfSpeech": "adjective", "cefr": "A1", "ipa": "dʒiˈfi.siw", "register": "neutral", "tags": ["adjective"], "examples": [{ "text": "Português não é tão difícil.", "translation": "Portuguese isn't that hard." }] },
  { "schemaVersion": 1, "key": "vocab.legal", "entryType": "word", "lemma": "legal", "translation": "cool / nice", "partOfSpeech": "adjective", "cefr": "A1", "ipa": "leˈgaw", "register": "informal", "tags": ["adjective", "brazil"], "literalMeaning": "legal (relating to law)", "naturalMeaning": "The default Brazilian word for 'cool/nice'; the legal sense exists but is much rarer in conversation.", "examples": [{ "text": "Que legal! Adorei.", "translation": "How cool! I loved it.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.branco", "entryType": "word", "lemma": "branco", "translation": "white", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["colors"] },
  { "schemaVersion": 1, "key": "vocab.preto", "entryType": "word", "lemma": "preto", "translation": "black", "partOfSpeech": "adjective", "cefr": "A1", "register": "neutral", "tags": ["colors"] },
  { "schemaVersion": 1, "key": "vocab.vermelho", "entryType": "word", "lemma": "vermelho", "translation": "red", "partOfSpeech": "adjective", "cefr": "A1", "ipa": "veʁˈme.ʎu", "register": "neutral", "tags": ["colors"] },
  { "schemaVersion": 1, "key": "vocab.azul", "entryType": "word", "lemma": "azul", "translation": "blue", "partOfSpeech": "adjective", "cefr": "A1", "ipa": "aˈzuw", "register": "neutral", "tags": ["colors"] },
  { "schemaVersion": 1, "key": "vocab.verde", "entryType": "word", "lemma": "verde", "translation": "green", "partOfSpeech": "adjective", "cefr": "A1", "ipa": "ˈveʁ.dʒi", "register": "neutral", "tags": ["colors"] },
  { "schemaVersion": 1, "key": "vocab.cidade", "entryType": "word", "lemma": "cidade", "translation": "city", "partOfSpeech": "noun", "cefr": "A1", "ipa": "siˈda.dʒi", "gender": "f", "register": "neutral", "tags": ["city"] },
  { "schemaVersion": 1, "key": "vocab.praia", "entryType": "word", "lemma": "praia", "translation": "beach", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈpɾaj.ɐ", "gender": "f", "register": "neutral", "tags": ["city", "brazil"], "examples": [{ "text": "Bora pra praia no domingo?", "translation": "Wanna hit the beach on Sunday?", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.mercado", "entryType": "word", "lemma": "mercado", "translation": "market / grocery store", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["city", "shopping"], "naturalMeaning": "In everyday speech, 'o mercado' usually means the supermarket." },
  { "schemaVersion": 1, "key": "vocab.padaria", "entryType": "word", "lemma": "padaria", "translation": "bakery", "partOfSpeech": "noun", "cefr": "A1", "gender": "f", "register": "neutral", "tags": ["city", "food-drink", "brazil"], "naturalMeaning": "Brazilian padarias are neighborhood hubs: fresh bread, coffee, snacks, often open late." },
  { "schemaVersion": 1, "key": "vocab.farmacia", "entryType": "word", "lemma": "farmácia", "translation": "pharmacy / drugstore", "partOfSpeech": "noun", "cefr": "A1", "ipa": "faʁˈma.sjɐ", "gender": "f", "register": "neutral", "tags": ["city", "health"] },
  { "schemaVersion": 1, "key": "vocab.banco", "entryType": "word", "lemma": "banco", "translation": "bank; bench", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["city", "money"] },
  { "schemaVersion": 1, "key": "vocab.banheiro", "entryType": "word", "lemma": "banheiro", "translation": "bathroom / restroom", "partOfSpeech": "noun", "cefr": "A1", "ipa": "bɐ̃ˈɲej.ɾu", "gender": "m", "register": "neutral", "tags": ["home", "city"], "examples": [{ "text": "Onde fica o banheiro?", "translation": "Where is the bathroom?" }] },
  { "schemaVersion": 1, "key": "vocab.onibus", "entryType": "word", "lemma": "ônibus", "translation": "bus", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈo.ni.bus", "gender": "m", "register": "neutral", "tags": ["transport"], "examples": [{ "text": "Vou pegar o ônibus.", "translation": "I'm going to take the bus." }] },
  { "schemaVersion": 1, "key": "vocab.carro", "entryType": "word", "lemma": "carro", "translation": "car", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈka.ʁu", "gender": "m", "register": "neutral", "tags": ["transport"], "pronunciationNotes": "Double-r is a harsh 'h' sound: KAH-hoo. Contrast with 'caro' (expensive), single flap r." },
  { "schemaVersion": 1, "key": "vocab.metro-subway", "entryType": "word", "lemma": "metrô", "translation": "subway / metro", "partOfSpeech": "noun", "cefr": "A1", "ipa": "meˈtɾo", "gender": "m", "register": "neutral", "tags": ["transport"], "pronunciationNotes": "Stress on the last syllable: me-TRO. 'Metro' (stress on first syllable) is the unit of measure." },
  { "schemaVersion": 1, "key": "vocab.apartamento", "entryType": "word", "lemma": "apartamento", "translation": "apartment", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["home"], "naturalMeaning": "Shortened to 'apê' in casual speech." },
  { "schemaVersion": 1, "key": "vocab.quarto", "entryType": "word", "lemma": "quarto", "translation": "bedroom; room", "partOfSpeech": "noun", "cefr": "A1", "gender": "m", "register": "neutral", "tags": ["home"], "naturalMeaning": "Also the fraction 'quarter'. A hotel room is also 'quarto'." },
  { "schemaVersion": 1, "key": "vocab.cozinha", "entryType": "word", "lemma": "cozinha", "translation": "kitchen", "partOfSpeech": "noun", "cefr": "A1", "ipa": "koˈzi.ɲɐ", "gender": "f", "register": "neutral", "tags": ["home"] },
  { "schemaVersion": 1, "key": "vocab.cabeca", "entryType": "word", "lemma": "cabeça", "translation": "head", "partOfSpeech": "noun", "cefr": "A1", "ipa": "kaˈbe.sɐ", "gender": "f", "register": "neutral", "tags": ["body"], "examples": [{ "text": "Tô com dor de cabeça.", "translation": "I have a headache.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.mao", "entryType": "word", "lemma": "mão", "translation": "hand", "partOfSpeech": "noun", "cefr": "A1", "ipa": "mɐ̃w̃", "gender": "f", "register": "neutral", "tags": ["body"], "naturalMeaning": "Feminine despite ending in -ão: a mão." },
  { "schemaVersion": 1, "key": "vocab.chuva", "entryType": "word", "lemma": "chuva", "translation": "rain", "partOfSpeech": "noun", "cefr": "A1", "ipa": "ˈʃu.vɐ", "gender": "f", "register": "neutral", "tags": ["weather"], "examples": [{ "text": "Vai ter chuva à tarde.", "translation": "It's going to rain in the afternoon." }] },
  { "schemaVersion": 1, "key": "vocab.sol", "entryType": "word", "lemma": "sol", "translation": "sun", "partOfSpeech": "noun", "cefr": "A1", "ipa": "sɔw", "gender": "m", "register": "neutral", "tags": ["weather"], "examples": [{ "text": "Hoje tá fazendo sol.", "translation": "It's sunny today.", "register": "informal" }] },
  { "schemaVersion": 1, "key": "vocab.calor", "entryType": "word", "lemma": "calor", "translation": "heat / hot weather", "partOfSpeech": "noun", "cefr": "A1", "ipa": "kaˈloʁ", "gender": "m", "register": "neutral", "tags": ["weather"], "examples": [{ "text": "Que calor hoje!", "translation": "It's so hot today!" }] },
  { "schemaVersion": 1, "key": "vocab.o-que", "entryType": "word", "lemma": "o que", "translation": "what", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["question"], "naturalMeaning": "At the end of a question it becomes 'o quê': 'Você quer o quê?'", "examples": [{ "text": "O que você faz?", "translation": "What do you do?" }] },
  { "schemaVersion": 1, "key": "vocab.quem", "entryType": "word", "lemma": "quem", "translation": "who", "partOfSpeech": "pronoun", "cefr": "A1", "ipa": "kẽj̃", "register": "neutral", "tags": ["question"], "examples": [{ "text": "Quem é ela?", "translation": "Who is she?" }] },
  { "schemaVersion": 1, "key": "vocab.quando", "entryType": "word", "lemma": "quando", "translation": "when", "partOfSpeech": "adverb", "cefr": "A1", "ipa": "ˈkwɐ̃.du", "register": "neutral", "tags": ["question"], "examples": [{ "text": "Quando você chega?", "translation": "When do you arrive?" }] },
  { "schemaVersion": 1, "key": "vocab.onde", "entryType": "word", "lemma": "onde", "translation": "where", "partOfSpeech": "adverb", "cefr": "A1", "ipa": "ˈõ.dʒi", "register": "neutral", "tags": ["question"], "examples": [{ "text": "Onde você mora?", "translation": "Where do you live?" }] },
  { "schemaVersion": 1, "key": "vocab.como", "entryType": "word", "lemma": "como", "translation": "how; like/as", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["question"], "examples": [{ "text": "Como funciona?", "translation": "How does it work?" }] },
  { "schemaVersion": 1, "key": "vocab.por-que", "entryType": "word", "lemma": "por que", "translation": "why", "partOfSpeech": "adverb", "cefr": "A1", "register": "neutral", "tags": ["question"], "naturalMeaning": "'Por que' asks why; 'porque' (one word) answers 'because'.", "examples": [{ "text": "Por que você estuda português?", "translation": "Why do you study Portuguese?" }] },
  { "schemaVersion": 1, "key": "vocab.eu", "entryType": "word", "lemma": "eu", "translation": "I", "partOfSpeech": "pronoun", "cefr": "A1", "frequencyRank": 15, "register": "neutral", "tags": ["pronoun"] },
  { "schemaVersion": 1, "key": "vocab.voce", "entryType": "word", "lemma": "você", "translation": "you", "partOfSpeech": "pronoun", "cefr": "A1", "frequencyRank": 25, "ipa": "voˈse", "register": "neutral", "tags": ["pronoun"], "naturalMeaning": "The standard 'you' in most of Brazil (not 'tu' in most regions, never 'vós'). Often shortened to 'cê' in speech." },
  { "schemaVersion": 1, "key": "vocab.ele", "entryType": "word", "lemma": "ele", "translation": "he / it", "partOfSpeech": "pronoun", "cefr": "A1", "ipa": "ˈe.li", "register": "neutral", "tags": ["pronoun"] },
  { "schemaVersion": 1, "key": "vocab.ela", "entryType": "word", "lemma": "ela", "translation": "she / it", "partOfSpeech": "pronoun", "cefr": "A1", "ipa": "ˈɛ.lɐ", "register": "neutral", "tags": ["pronoun"] },
  { "schemaVersion": 1, "key": "vocab.nos", "entryType": "word", "lemma": "nós", "translation": "we", "partOfSpeech": "pronoun", "cefr": "A1", "ipa": "nɔs", "register": "neutral", "tags": ["pronoun"], "naturalMeaning": "In everyday speech Brazilians usually say 'a gente' (with singular verb) instead: 'A gente vai.'" },
  { "schemaVersion": 1, "key": "vocab.isso", "entryType": "word", "lemma": "isso", "translation": "this / that", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["pronoun"], "naturalMeaning": "'Isso!' by itself means 'Exactly! That's it!'", "examples": [{ "text": "O que é isso?", "translation": "What is that?" }] },
  { "schemaVersion": 1, "key": "vocab.meu", "entryType": "word", "lemma": "meu", "translation": "my / mine", "partOfSpeech": "pronoun", "cefr": "A1", "register": "neutral", "tags": ["pronoun"], "naturalMeaning": "Agrees with the thing owned: meu carro, minha casa.", "examples": [{ "text": "Esse é o meu celular.", "translation": "That's my phone." }] },
  { "schemaVersion": 1, "key": "vocab.de", "entryType": "word", "lemma": "de", "translation": "of / from", "partOfSpeech": "preposition", "cefr": "A1", "frequencyRank": 2, "ipa": "dʒi", "register": "neutral", "tags": ["preposition"], "naturalMeaning": "Contracts with articles: de + o = do, de + a = da.", "examples": [{ "text": "Eu sou dos Estados Unidos.", "translation": "I'm from the United States." }] },
  { "schemaVersion": 1, "key": "vocab.em", "entryType": "word", "lemma": "em", "translation": "in / on / at", "partOfSpeech": "preposition", "cefr": "A1", "frequencyRank": 6, "ipa": "ẽj̃", "register": "neutral", "tags": ["preposition"], "naturalMeaning": "Contracts with articles: em + o = no, em + a = na.", "examples": [{ "text": "Moro no centro.", "translation": "I live downtown." }] },
